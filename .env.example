# Copiar a .env.local y completar con los valores del proyecto de Supabase
# (Project Settings -> API). El archivo .env.local NUNCA se commitea.

# URL del proyecto, ej: https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Clave publica (anon / public). Es publica por diseno: viaja al navegador.
# Lo que protege los datos es Row Level Security en la base, no esta clave.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clave service_role: SOLO del lado del servidor, nunca con prefijo
# NEXT_PUBLIC_. Saltea todos los candados de RLS. La usa unicamente el
# webhook de Mercado Pago (Fase 3) para escribir el estado de suscripcion,
# el unico lugar autorizado a hacerlo.
SUPABASE_SERVICE_ROLE_KEY=

# URL publica del sitio. En desarrollo local es http://localhost:3000.
# Se usa para armar los links que Supabase manda por email (confirmacion,
# recuperar contrasena). En produccion (Fase 8) hay que cambiarla por la URL real.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Mercado Pago (Fase 3) ---

# Access Token de PRUEBA. Autoriza al servidor a crear planes/suscripciones
# y a consultar el estado real de una suscripcion en la API de Mercado Pago.
# Nunca con prefijo NEXT_PUBLIC_: no debe llegar al navegador.
MERCADOPAGO_ACCESS_TOKEN=

# Public Key de PRUEBA. Es publica por diseno (la necesita el boton
# "Suscribirme" en el navegador para iniciar el checkout) - no protege nada
# por si sola, igual que la anon key de Supabase.
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=

# Secreto de firma del webhook. Lo genera Mercado Pago al configurar la URL
# de notificaciones en el panel de desarrolladores (se completa mas
# adelante en esta misma fase, cuando tengamos esa URL). Se usa SOLO para
# verificar que una notificacion entrante es autentica; nunca al navegador.
# Para probar el webhook en local (sin URL publica) se usa un valor temporal
# cualquiera - ver scripts/simular-webhook.ts.
MERCADOPAGO_WEBHOOK_SECRET=
